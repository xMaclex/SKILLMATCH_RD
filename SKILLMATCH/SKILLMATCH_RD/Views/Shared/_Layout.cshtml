<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SKILLMATCH RD</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SKILLMATCH_RD.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-skillmatch mb-0">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    &#9670; SKILLMATCH RD
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Ofertas" asp-action="Index">Ofertas</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                Para Empresas
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Empresas" asp-action="Registro">Registrar Empresa</a></li>
                                <li><a class="dropdown-item" asp-controller="Empresas" asp-action="Dashboard">Mi Panel</a></li>
                                <li><a class="dropdown-item" asp-controller="Ofertas" asp-action="Crear">Publicar Oferta</a></li>
                                <li><a class="dropdown-item" asp-controller="Empresas" asp-action="Index">Empresas Registradas</a></li>
                                <li><a class="dropdown-item" asp-controller="Solicitudes" asp-action="Index">Solicitudes</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                Para Estudiantes
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Estudiantes" asp-action="Registro">Registrarme</a></li>
                                <li><a class="dropdown-item" asp-controller="Estudiantes" asp-action="Index">Mi Perfil</a></li>
                                <li><a class="dropdown-item" asp-controller="Estudiantes" asp-action="MisOfertas">Mis Recomendaciones</a></li>
                            </ul>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        @if (Context.Session.GetString("UsuarioNombre") != null)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    @Context.Session.GetString("UsuarioNombre")
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><span class="dropdown-item-text text-muted small">@Context.Session.GetString("UsuarioTipo")</span></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><a class="dropdown-item" asp-controller="Auth" asp-action="Logout">Cerrar Sesion</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Auth" asp-action="Login">
                                    Iniciar Sesion
                                </a>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="btn btn-sm" style="background:#C8102E;color:white;padding:6px 14px;border-radius:6px;"
                                   asp-controller="Estudiantes" asp-action="Registro">
                                    Registrarme
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer border-top text-muted mt-5">
        <div class="container py-3 d-flex justify-content-between align-items-center">
            <span>&copy; 2026 <strong>SKILLMATCH RD</strong> &mdash; Conectando talento ITLA con el mercado laboral</span>
            <span class="text-muted small">Adrian Reyes &amp; Michael Sanchez &mdash; ITLA</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
