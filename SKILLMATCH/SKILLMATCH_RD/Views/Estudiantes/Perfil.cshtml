@model SKILLMATCH_RD.Models.Estudiante
@{
    ViewData["Title"] = "Perfil de Estudiante";
}

<div class="page-header">
    <div class="container">
        <h2>@Model.NombreCompleto</h2>
        <p class="text-muted mb-0">@Model.Carrera &bull; Semestre @Model.SemestreActual</p>
    </div>
</div>

<div class="container" style="max-width:760px;">
    <div class="card border-0 shadow-sm p-4 mb-3">
        <div class="row g-3">
            <div class="col-md-6"><span class="text-muted small">Matricula</span><div class="fw-semibold">@Model.Matricula</div></div>
            <div class="col-md-6"><span class="text-muted small">Correo</span><div class="fw-semibold">@Model.Email</div></div>
            <div class="col-md-6"><span class="text-muted small">Universidad</span><div class="fw-semibold">@(Model.Universidad?.Nombre ?? "ITLA")</div></div>
            <div class="col-md-6"><span class="text-muted small">Registrado</span><div class="fw-semibold">@Model.FechaRegistro.ToString("dd/MM/yyyy")</div></div>
            <div class="col-12">
                <span class="text-muted small">Busca</span>
                <div>
                    @if (Model.BuscaPasantia) { <span class="badge badge-pasantia">Pasantia</span> }
                    @if (Model.BuscaEmpleo) { <span class="badge badge-empleo">Empleo</span> }
                </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.Descripcion))
            {
                <div class="col-12"><span class="text-muted small">Sobre mi</span><p class="mb-0">@Model.Descripcion</p></div>
            }
            <div class="col-12">
                <span class="text-muted small d-block mb-1">Aptitudes</span>
                @foreach (var a in Model.Aptitudes)
                {
                    <span class="badge bg-light text-dark border">@a.Nombre</span>
                }
            </div>
        </div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Volver al listado</a>
</div>
