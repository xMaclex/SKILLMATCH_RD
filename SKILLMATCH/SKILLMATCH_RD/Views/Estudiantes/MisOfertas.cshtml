@{
    ViewData["Title"] = "Mis Recomendaciones";
}

<div class="page-header">
    <div class="container">
        <h2>Hola, @ViewBag.NombreEstudiante</h2>
        <p class="text-muted mb-0">Ofertas recomendadas segun tu perfil y aptitudes registradas</p>
    </div>
</div>

<div class="container">

    <div class="row g-3">
        @foreach (dynamic rec in ViewBag.Recomendaciones)
        {
            int match = (int)rec.Match;
            string barColor = match >= 85 ? "bg-success" : match >= 75 ? "bg-primary" : "bg-warning";
            string textColor = match >= 85 ? "text-success" : match >= 75 ? "text-primary" : "text-warning";

            <div class="col-12">
                <div class="card border-0 shadow-sm p-4">
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                @if (rec.Tipo == "Pasantia")
                                {
                                    <span class="badge badge-pasantia">Pasantia</span>
                                }
                                else
                                {
                                    <span class="badge badge-empleo">Empleo</span>
                                }
                                <span class="text-muted small">@rec.Ciudad &bull; @rec.Modalidad</span>
                            </div>
                            <h5 class="fw-bold mb-1">@rec.Titulo</h5>
                            <p class="text-muted mb-2">@rec.Empresa</p>
                            <div class="d-flex gap-1 flex-wrap">
                                @foreach (string apt in rec.Aptitudes)
                                {
                                    <span class="badge bg-light text-dark border">@apt</span>
                                }
                            </div>
                        </div>
                        <div class="col-md-4 text-md-end mt-3 mt-md-0">
                            <div class="@textColor fw-bold" style="font-size:2rem;">@match%</div>
                            <div class="text-muted small mb-2">Compatibilidad</div>
                            <div class="progress mb-3" style="height:8px;">
                                <div class="progress-bar @barColor" style="width:@match%"></div>
                            </div>
                            <button class="btn btn-skillmatch btn-sm px-4">Aplicar</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

</div>
