@{
    ViewData["Title"] = "Mis Recomendaciones";
}

<div class="page-header">
    <div class="container">
        <h2>Ofertas Recomendadas para Ti</h2>
        <p class="text-muted mb-0">Basadas en tu carrera y aptitudes registradas</p>
    </div>
</div>

<div class="container">
    <div class="alert alert-warning" role="alert">
        &#9888; El motor de matching se encuentra en desarrollo. Pronto veras aqui tus recomendaciones personalizadas.
    </div>

    <div class="row g-3">
        <div class="col-12">
            <div class="card border-0 shadow-sm p-4" style="opacity:0.6;">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <span class="badge badge-pasantia me-2">Pasantia</span>
                        <h5 class="mt-2 mb-1">Desarrollador Junior (Vista Previa)</h5>
                        <p class="text-muted small mb-1">Empresa Ejemplo &bull; Santo Domingo</p>
                    </div>
                    <div class="text-end">
                        <div class="fw-bold text-success fs-5">85%</div>
                        <div class="text-muted small">Compatibilidad</div>
                    </div>
                </div>
                <div class="progress mt-3" style="height:8px;">
                    <div class="progress-bar bg-success" style="width:85%"></div>
                </div>
            </div>
        </div>
    </div>
</div>
