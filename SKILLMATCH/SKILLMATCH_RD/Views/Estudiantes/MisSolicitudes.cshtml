@model List<SKILLMATCH_RD.Models.Solicitud>
@{
    ViewData["Title"] = "Mis Solicitudes";
}

<div class="page-header">
    <div class="container">
        <h2>Mis Solicitudes</h2>
        <p class="text-muted mb-0">Seguimiento de tus postulaciones</p>
    </div>
</div>

<div class="container">
    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success mb-4">@TempData["Mensaje"]</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">Aun no has postulado a ninguna oferta. Revisa las <a asp-controller="Ofertas" asp-action="Index">ofertas disponibles</a>.</div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Oferta</th>
                            <th>Empresa</th>
                            <th class="text-center">Match</th>
                            <th class="text-center">Estado</th>
                            <th>Fecha</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@s.Oferta?.Titulo</td>
                                <td>@s.Oferta?.Empresa?.Nombre</td>
                                <td class="text-center">@s.PorcentajeMatch%</td>
                                <td class="text-center"><span class="badge bg-secondary">@s.EstadoTexto</span></td>
                                <td>@s.FechaSolicitud.ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
