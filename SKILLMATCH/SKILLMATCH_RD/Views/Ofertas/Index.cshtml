@{
    ViewData["Title"] = "Ofertas Disponibles";
}

<div class="page-header">
    <div class="container d-flex justify-content-between align-items-center">
        <div>
            <h2>Ofertas Disponibles</h2>
            <p class="text-muted mb-0">Empleos y pasantias para estudiantes del ITLA y universidades tecnicas</p>
        </div>
        <div class="d-flex gap-2">
            <select class="form-select" style="width:auto;">
                <option>Todos los tipos</option>
                <option>Empleo</option>
                <option>Pasantia</option>
            </select>
            <select class="form-select" style="width:auto;">
                <option>Todas las carreras</option>
                <option>Desarrollo de Software</option>
                <option>Redes</option>
                <option>Soporte Tecnico</option>
            </select>
        </div>
    </div>
</div>

<div class="container">
    <div class="alert alert-info mb-4">
        Las ofertas se cargaran aqui una vez que las empresas registradas comiencen a publicarlas.
        <a asp-controller="Empresas" asp-action="Registro">Eres empresa? Registrate aqui.</a>
    </div>

    <!-- Placeholder de oferta de ejemplo -->
    <div class="row g-3" style="opacity:0.5;pointer-events:none;">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm p-3">
                <div class="d-flex justify-content-between">
                    <span class="badge" style="background:var(--sm-primary);color:white;">Pasantia</span>
                    <span class="text-muted small">Hace 2 dias</span>
                </div>
                <h6 class="fw-bold mt-2 mb-1">Desarrollador Web Junior</h6>
                <p class="text-muted small mb-2">TechCorp RD &bull; Santo Domingo &bull; Presencial</p>
                <div class="d-flex gap-1 flex-wrap mb-3">
                    <span class="badge bg-light text-dark">C#</span>
                    <span class="badge bg-light text-dark">SQL</span>
                    <span class="badge bg-light text-dark">HTML/CSS</span>
                </div>
                <a class="btn btn-skillmatch-outline btn-sm">Ver Detalle</a>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm p-3">
                <div class="d-flex justify-content-between">
                    <span class="badge" style="background:#0d9488;color:white;">Empleo</span>
                    <span class="text-muted small">Hace 5 dias</span>
                </div>
                <h6 class="fw-bold mt-2 mb-1">Tecnico de Soporte IT</h6>
                <p class="text-muted small mb-2">Banco Digital RD &bull; Santiago &bull; Hibrido</p>
                <div class="d-flex gap-1 flex-wrap mb-3">
                    <span class="badge bg-light text-dark">Windows Server</span>
                    <span class="badge bg-light text-dark">Redes</span>
                </div>
                <a class="btn btn-skillmatch-outline btn-sm">Ver Detalle</a>
            </div>
        </div>
    </div>
</div>
