@model List<SKILLMATCH_RD.Models.Oferta>
@{
    ViewData["Title"] = "Ofertas Disponibles";
    string tipoFiltro    = ViewBag.TipoFiltro    as string ?? "";
    string carreraFiltro = ViewBag.CarreraFiltro as string ?? "";
}

<div class="page-header">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h2>Ofertas Disponibles</h2>
                <p class="text-muted mb-0">@ViewBag.TotalOfertas ofertas activas para estudiantes del ITLA</p>
            </div>
            <form method="get" class="d-flex gap-2 flex-wrap">
                <select name="tipo" class="form-select" style="width:auto;" onchange="this.form.submit()">
                    <option value="">Todos los tipos</option>
                    @if (tipoFiltro == "Empleo") { <option value="Empleo" selected>Empleo</option> } else { <option value="Empleo">Empleo</option> }
                    @if (tipoFiltro == "Pasantia") { <option value="Pasantia" selected>Pasantia</option> } else { <option value="Pasantia">Pasantia</option> }
                </select>
                <select name="carrera" class="form-select" style="width:auto;" onchange="this.form.submit()">
                    <option value="">Todas las carreras</option>
                    @{
                        var carreras = new[] { "Desarrollo de Software", "Redes y Telecomunicaciones", "Soporte Tecnico", "Seguridad Informatica", "Diseno Grafico" };
                        foreach (var c in carreras)
                        {
                            if (carreraFiltro == c) { <option value="@c" selected>@c</option> } else { <option value="@c">@c</option> }
                        }
                    }
                </select>
            </form>
        </div>
    </div>
</div>

<div class="container">

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success mb-4">@TempData["Mensaje"]</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">No se encontraron ofertas con esos filtros.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var oferta in Model)
            {
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm h-100 p-3">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            @if (oferta.Tipo == SKILLMATCH_RD.Models.Enums.TipoOferta.Pasantia)
                            {
                                <span class="badge badge-pasantia">Pasantia</span>
                            }
                            else
                            {
                                <span class="badge badge-empleo">Empleo</span>
                            }
                            <span class="text-muted small">Hace @((DateTime.Now - oferta.FechaPublicacion).Days) dias</span>
                        </div>

                        <h6 class="fw-bold mb-1">@oferta.Titulo</h6>
                        <p class="text-muted small mb-1">
                            <strong>@oferta.Empresa?.Nombre</strong> &bull; @oferta.Empresa?.Ciudad &bull; @oferta.Modalidad
                        </p>
                        <p class="text-muted small mb-2">Carrera: @oferta.CarreraRequerida &bull; Desde semestre @oferta.SemestreMinimo</p>

                        <p class="small text-secondary mb-3">@oferta.Descripcion</p>

                        <div class="d-flex gap-1 flex-wrap mb-3">
                            @foreach (var apt in oferta.AptitudesRequeridas)
                            {
                                <span class="badge bg-light text-dark border">@apt.Nombre</span>
                            }
                        </div>

                        <div class="d-flex gap-2 mt-auto">
                            <a asp-action="Detalle" asp-route-id="@oferta.Id"
                               class="btn btn-skillmatch-outline btn-sm">Ver Detalle</a>
                            <a asp-controller="Auth" asp-action="Login"
                               class="btn btn-skillmatch btn-sm">Aplicar</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
