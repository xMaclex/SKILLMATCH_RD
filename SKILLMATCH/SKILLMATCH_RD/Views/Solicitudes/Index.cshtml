@model List<SKILLMATCH_RD.Models.Solicitud>
@{
    ViewData["Title"] = "Solicitudes";
}

<div class="page-header">
    <div class="container">
        <h2>Gestion de Solicitudes</h2>
        <p class="text-muted mb-0">@Model.Count postulaciones registradas en la base de datos</p>
    </div>
</div>

<div class="container">
    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success mb-4">@TempData["Mensaje"]</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">Aun no hay postulaciones registradas.</div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Estudiante</th>
                            <th>Oferta</th>
                            <th>Empresa</th>
                            <th class="text-center">Match</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@s.Estudiante?.Nombre @s.Estudiante?.Apellido</div>
                                    <div class="text-muted small">@s.Estudiante?.Carrera</div>
                                </td>
                                <td>@s.Oferta?.Titulo</td>
                                <td>@s.Oferta?.Empresa?.Nombre</td>
                                <td class="text-center fw-semibold">@s.PorcentajeMatch%</td>
                                <td><span class="badge bg-secondary">@s.EstadoTexto</span></td>
                                <td class="text-end">
                                    <form asp-action="ActualizarEstado" method="post" class="d-inline-flex gap-1 align-items-center">
                                        <input type="hidden" name="id" value="@s.Id" />
                                        <select name="estado" class="form-select form-select-sm" style="width:auto;">
                                            <option value="Pendiente"  selected="@(s.Estado == SKILLMATCH_RD.Models.Enums.EstadoSolicitud.Pendiente)">Pendiente</option>
                                            <option value="EnRevision" selected="@(s.Estado == SKILLMATCH_RD.Models.Enums.EstadoSolicitud.EnRevision)">En Revision</option>
                                            <option value="Aceptada"   selected="@(s.Estado == SKILLMATCH_RD.Models.Enums.EstadoSolicitud.Aceptada)">Aceptada</option>
                                            <option value="Rechazada"  selected="@(s.Estado == SKILLMATCH_RD.Models.Enums.EstadoSolicitud.Rechazada)">Rechazada</option>
                                        </select>
                                        <button type="submit" class="btn btn-skillmatch-outline btn-sm">Actualizar</button>
                                    </form>
                                    <form asp-action="Eliminar" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@s.Id" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm">Eliminar</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
